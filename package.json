{
  "name": "negentropy-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Negentropy monorepo root — apps + shared packages",
  "scripts": {
    "build": "pnpm -r --filter='./apps/*' --filter='./packages/*' build",
    "lint": "pnpm -r --filter='./apps/*' --filter='./packages/*' lint",
    "test": "pnpm -r --filter='./apps/*' --filter='./packages/*' test",
    "typecheck": "pnpm -r --filter='./apps/*' --filter='./packages/*' typecheck",
    "build:core": "pnpm --filter @negentropy/agents-chat-core build",
    "test:core": "pnpm --filter @negentropy/agents-chat-core test",
    "dev:ui": "pnpm --filter negentropy-ui dev",
    "dev:wiki": "pnpm --filter negentropy-wiki dev"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "engines": {
    "node": ">=20"
  }
}
