{
  "name": "negentropy-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -H localhost -p 3333",
    "build": "next build",
    "start": "PORT=3333 HOSTNAME=localhost node ./scripts/start-production.mjs",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p tsconfig.vitest.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:chat-smoke": "playwright test -g \"聊天流式 Markdown 表格与换行在 hydration 后无需刷新即可稳定收敛\""
  },
  "dependencies": {
    "@ag-ui/client": "0.0.47",
    "@ag-ui/core": "0.0.47",
    "@ag-ui/encoder": "0.0.47",
    "@copilotkitnext/react": "1.51.3",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.12.2",
    "micromark": "^4.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "rxjs": "7.8.1",
    "sonner": "^2.0.7",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
