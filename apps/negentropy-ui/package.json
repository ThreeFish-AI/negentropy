{
  "name": "negentropy-ui",
  "version": "0.0.1a1",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @negentropy/agents-chat-core build",
    "dev": "next dev --webpack -H localhost -p 3192",
    "prebuild": "test -n \"$NEGENTROPY_CORE_PREBUILT\" || pnpm --filter @negentropy/agents-chat-core build",
    "build": "next build",
    "start": "node ./scripts/start-production.mjs",
    "prelint": "pnpm --filter @negentropy/agents-chat-core build",
    "lint": "eslint . --max-warnings=0",
    "pretypecheck": "pnpm --filter @negentropy/agents-chat-core build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretypecheck:test": "pnpm --filter @negentropy/agents-chat-core build",
    "typecheck:test": "tsc -p tsconfig.vitest.json --noEmit",
    "pretest": "pnpm --filter @negentropy/agents-chat-core build",
    "test": "vitest run",
    "pretest:watch": "pnpm --filter @negentropy/agents-chat-core build",
    "test:watch": "vitest",
    "pretest:coverage": "pnpm --filter @negentropy/agents-chat-core build",
    "test:coverage": "vitest run --coverage",
    "pretest:e2e": "pnpm --filter @negentropy/agents-chat-core build",
    "test:e2e": "playwright test",
    "test:e2e:chat-smoke": "playwright test -g \"聊天流式 Markdown 表格与换行在 hydration 后无需刷新即可稳定收敛\""
  },
  "dependencies": {
    "@ag-ui/client": "0.0.47",
    "@ag-ui/core": "0.0.47",
    "@ag-ui/encoder": "0.0.47",
    "@copilotkitnext/react": "1.51.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@negentropy/agents-chat-core": "workspace:*",
    "@radix-ui/react-tooltip": "^1.2.8",
    "cytoscape": "^3.33.3",
    "cytoscape-fcose": "^2.2.0",
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "framer-motion": "^12.40.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.33",
    "lucide-react": "^0.525.0",
    "mermaid": "^11.12.2",
    "micromark": "^4.0.0",
    "micromark-extension-gfm": "^3.0.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-force-graph-2d": "^1.29.1",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rxjs": "7.8.1",
    "sigma": "^3.0.3",
    "sonner": "^2.0.7",
    "three-spritetext": "^1.10.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cytoscape": "^3.31.0",
    "@types/d3-drag": "^3.0.7",
    "@types/d3-force": "^3.0.10",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/node": "^20",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6.4.2",
    "vitest": "^4.0.18"
  }
}
