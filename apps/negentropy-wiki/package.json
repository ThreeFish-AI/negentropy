{
  "name": "negentropy-wiki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "test -d node_modules/@negentropy/agents-chat-core/dist || pnpm --filter @negentropy/agents-chat-core build",
    "dev": "next dev --port 3092",
    "prebuild": "test -d node_modules/@negentropy/agents-chat-core/dist || pnpm --filter @negentropy/agents-chat-core build",
    "build": "next build",
    "start": "node ./scripts/start-production.mjs",
    "prelint": "test -d node_modules/@negentropy/agents-chat-core/dist || pnpm --filter @negentropy/agents-chat-core build",
    "lint": "eslint .",
    "pretest": "test -d node_modules/@negentropy/agents-chat-core/dist || pnpm --filter @negentropy/agents-chat-core build",
    "test": "vitest run",
    "pretest:watch": "test -d node_modules/@negentropy/agents-chat-core/dist || pnpm --filter @negentropy/agents-chat-core build",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ag-ui/client": "catalog:",
    "@ag-ui/core": "catalog:",
    "@negentropy/agents-chat-core": "workspace:*",
    "github-slugger": "^2.0.0",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.47",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "ogl": "^1.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "rxjs": "catalog:",
    "sigma": "^3.0.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.13.0",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@vitejs/plugin-react": "^5.0.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^28.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.3"
  }
