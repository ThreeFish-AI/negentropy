{
  "name": "@negentropy/agents-chat-core",
  "version": "0.0.1-rc.2",
  "private": true,
  "description": "AGUI 协议层与 Mention 解析共享库（一主五翼 6 Agents 对话协议 SSOT）",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./protocol": {
      "types": "./dist/protocol/index.d.ts",
      "import": "./dist/protocol/index.js",
      "require": "./dist/protocol/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./parse": {
      "types": "./dist/parse/index.d.ts",
      "import": "./dist/parse/index.js",
      "require": "./dist/parse/index.cjs"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@ag-ui/client": "0.0.47",
    "@ag-ui/core": "0.0.47",
    "rxjs": "7.8.1",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@ag-ui/client": "catalog:",
    "@ag-ui/core": "catalog:",
    "@types/node": "^22.13.0",
    "rxjs": "catalog:",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^4.1.3",
    "zod": "catalog:"
  }
}
